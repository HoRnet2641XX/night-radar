# App
NEXT_PUBLIC_SITE_URL=http://localhost:3010
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
# Required before running /api/cron/crawl in production.
CRON_SECRET=
# All active sources are crawled in parallel every five minutes.
CRON_MAX_CRAWLS_PER_RUN=30
# Limits simultaneous requests while still completing every store in one run.
CRON_CRAWL_CONCURRENCY=8
# Failed, blocked, or parser-drop sources are retried once before the run fails.
CRAWL_RETRY_COUNT=1
CRAWL_RETRY_DELAY_MS=250
# A rotating subset receives a real browser capture on each run.
# With 25 sources and 3 captures/run, every source is captured about every 45 minutes.
CRON_SCREENSHOTS_PER_RUN=3

# Supabase Auth / DB
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OAuth providers are configured inside Supabase:
# - Google provider
# - X provider. Supabase provider id used by the app: x

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_LIGHT=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=

# AI analysis
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Scraping safety
# Optional comma-separated host allowlist. Empty means any public http/https host except local/private IPs.
SCRAPE_ALLOWED_HOSTS=
# Optional milliseconds. Keep this below external cron timeout; split batches for reliability.
SCRAPE_FETCH_TIMEOUT_MS=8000
# Optional remote-browser fallback used only after direct retrieval fails.
# Browserless Content API: https://docs.browserless.io/rest-apis/content
BROWSERLESS_API_TOKEN=
BROWSERLESS_CONTENT_ENDPOINT=https://production-sfo.browserless.io/content
SCRAPE_BROWSERLESS_TIMEOUT_MS=12000
# Set true if the runtime cannot launch Playwright. Text snapshots and radar metrics still work.
DISABLE_BROWSER_SCREENSHOTS=
# Real screenshots use a separate cron route so text crawling stays below 30 seconds.
BROWSER_SCREENSHOT_TIMEOUT_MS=10000
BROWSER_SCREENSHOT_SETTLE_MS=180
SCREENSHOT_INTERVAL_MINUTES=30
SCREENSHOT_MAX_PER_RUN=3

# Raw history retention. Daily/hourly aggregates are kept before raw rows are removed.
SNAPSHOT_RETENTION_DAYS=14
CRAWL_RUN_RETENTION_DAYS=30
NORMALIZED_POST_RETENTION_DAYS=90

# Notification delivery
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=Night Radar <notifications@example.com>
NOTIFICATION_WEBHOOK_URL=
# Slack Incoming Webhook、Discord Webhook、またはJSONを受け取れる運用Webhook。
OPERATION_ALERT_WEBHOOK_URL=
OPERATION_ALERT_EMAIL=
# 0 の場合だけ巡回失敗・解析急減の通知を止めます。
CRAWL_FAILURE_NOTIFICATIONS=1
# 直前の有効投稿数と比べた解析急減の検知条件。
CRAWL_PARSE_DROP_MIN_PREVIOUS=10
CRAWL_PARSE_DROP_MAX_RATIO=0.35
# 日次品質監査。0 の場合だけ異常通知を止めます。
DATA_QUALITY_ALERTS=1
DATA_QUALITY_SOURCE_STALE_MINUTES=15
DATA_QUALITY_MIN_TIMESTAMP_COVERAGE=90
